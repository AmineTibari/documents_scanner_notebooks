import json
import re

def post_traitement_universel(data):
    """
    Corrige uniquement les erreurs TECHNIQUES de Gemma
    Indépendant du type de document
    """

    # Markdown links existent dans tout document
    def nettoyer_markdown(obj):
        if isinstance(obj, str):
            obj = re.sub(r'\[([^\]]+)\]\(mailto:[^\)]+\)',
                        lambda m: m.group(1), obj)
            obj = re.sub(r'\[([^\]]+)\]\(http[^\)]+\)',
                        lambda m: m.group(1), obj)
            if obj.strip().upper() in ["N/A","NA","-","NONE","","NULL"]:
                return None
            return obj.strip()
        elif isinstance(obj, dict):
            return {k: nettoyer_markdown(v) for k, v in obj.items()}
        elif isinstance(obj, list):
            return [nettoyer_markdown(i) for i in obj]
        return obj

    # Les valeurs vides n'ont aucune valeur métier
    def supprimer_vides(obj):
        if isinstance(obj, dict):
            return {
                k: supprimer_vides(v)
                for k, v in obj.items()
                if supprimer_vides(v) not in [None, "", [], {}]
            }
        elif isinstance(obj, list):
            return [supprimer_vides(i) for i in obj if i is not None]
        return obj

    # JSON invalide avec clés dupliquées
    def corriger_cles_dupliquees(obj):
        if isinstance(obj, dict):
            cles_similaires = {}
            for k in obj.keys():
                base = re.sub(r'_\d+$', '', k)
                if base not in cles_similaires:
                    cles_similaires[base] = []
                cles_similaires[base].append(k)

            resultat = {}
            for base, cles in cles_similaires.items():
                if len(cles) == 1:
                    resultat[cles[0]] = corriger_cles_dupliquees(
                        obj[cles[0]]
                    )
                else:
                    # Fusionner en tableau
                    resultat[base] = [
                        corriger_cles_dupliquees(obj[k])
                        for k in cles
                    ]
            return resultat
        elif isinstance(obj, list):
            return [corriger_cles_dupliquees(i) for i in obj]
        return obj

    # JSON string imbriqué
    def corriger_json_imbrique(obj):
        if isinstance(obj, str):
            try:
                parse = json.loads(obj)
                return corriger_json_imbrique(parse)
            except:
                return obj
        elif isinstance(obj, dict):
            return {k: corriger_json_imbrique(v) for k, v in obj.items()}
        elif isinstance(obj, list):
            return [corriger_json_imbrique(i) for i in obj]
        return obj

    # Pipeline
    data = nettoyer_markdown(data)
    data = supprimer_vides(data)
    data = corriger_cles_dupliquees(data)
    data = corriger_json_imbrique(data)

    return data

