def preparer_texte_final(predictions):
    lignes = []
    for result in predictions:
        for tl in result.text_lines:
            lignes.append({
                "text": tl.text.strip(),
                "x":    round(tl.bbox[0]),
                "y":    round(tl.bbox[1]),
                "conf": tl.confidence
            })

    # Grouper par lignes horizontales
    lignes.sort(key=lambda l: l["y"])
    groupes = []
    groupe_actuel = [lignes[0]]

    for ligne in lignes[1:]:
        if abs(ligne["y"] - groupe_actuel[0]["y"]) <= 10:
            groupe_actuel.append(ligne)
        else:
            groupes.append(groupe_actuel)
            groupe_actuel = [ligne]
    groupes.append(groupe_actuel)

    resultat = []
    y_precedent = -1

    for groupe in groupes:
        groupe.sort(key=lambda l: l["x"])
        y = groupe[0]["y"]

        if y_precedent > 0 and (y - y_precedent) > 40:
            resultat.append("---")

        if len(groupe) == 1:
            resultat.append(groupe[0]["text"])
        else:
            parties = " | ".join([el["text"] for el in groupe])
            resultat.append(parties)

        y_precedent = y

    return "\n".join(resultat)

