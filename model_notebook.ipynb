from transformers import AutoProcessor, AutoModelForCausalLM
import torch

model_id = "google/gemma-3-4b-it"

model = AutoModelForCausalLM.from_pretrained(
    model_id,
    device_map="auto",
    torch_dtype="auto"
).eval()

processor = AutoProcessor.from_pretrained(model_id)

---------
cellule 6
---------


prompt = f"""Tu es un expert en analyse de documents administratifs et comptables.

LÉGENDE :
- "---" = séparateur entre sections
- " | " = colonnes séparées = sections INDÉPENDANTES, ne jamais fusionner

TEXTE :
{texte_brut}

RÈGLES :
1. Identifie le type de document
2. Extrait TOUTES les informations sans exception
3. Colonnes séparées par | = clés JSON distinctes
4. Produits/services toujours dans un tableau "produits": []
5. Jamais dupliquer une clé JSON
6. Jamais mettre null si la valeur existe
7. Ignorer les zones vides : Visa, Signature, Reçu le, Livré le
8. Corriger les erreurs OCR évidentes

RETOURNE UNIQUEMENT le JSON valide, sans markdown."""

---------
cellule 7
---------

messages = [
    {
        "role": "system",
        "content": [{"type": "text", "text": "You are a helpful assistant."}]
    },
    {
        "role": "user",
        "content": [
            {"type": "text", "text": prompt}
        ]
    }
]

inputs = processor.apply_chat_template(
    messages,

    add_generation_prompt=True, tokenize=True,
    return_dict=True, return_tensors="pt"
).to(model.device)

input_len = inputs["input_ids"].shape[-1]

with torch.inference_mode():
    generation = model.generate(**inputs, max_new_tokens=1024, do_sample=False)
    generation = generation[0][input_len:]

decoded = processor.decode(generation, skip_special_tokens=True)

print(decoded)


